# ─────────────────────────────────────────────────────────────────────────────
# Jarvis Sense — configuração. Copie para `.env`. Tudo aqui é OPCIONAL: há
# defaults sãos para todos os campos. As chaves espelham as do Jarvis web.
# ─────────────────────────────────────────────────────────────────────────────

# === Cérebro (LLM de texto) ===================================================
# Groq é o padrão (gratuito, compatível com OpenAI). Reaproveite a mesma chave
# que o jarvis-command-center já usa.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (fallback). Se ausente, o cérebro usa só o Groq.
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama local (100% offline/gratuito). Requer `ollama serve` rodando.
# JARVIS_OLLAMA_BASE_URL=http://localhost:11434
# JARVIS_OLLAMA_MODEL=gemma3:4b

# Força um provedor: "groq" | "anthropic" | "ollama". Vazio = automático (Groq primeiro).
# JARVIS_LLM_PROVIDER=groq

# === Voz do Jarvis (TTS) ======================================================
# Motor: "edge" (neural, online, padrão) | "sapi" (offline Windows).
JARVIS_TTS_ENGINE=edge
# Voz do edge-tts em pt-BR (masculina por padrão p/ combinar com o Jarvis).
JARVIS_TTS_VOICE=pt-BR-AntonioNeural
JARVIS_TTS_RATE=+6%
# Trecho do nome do dispositivo de saída a forçar (mesmo motivo do
# JARVIS_MIC_DEVICE_NAME: contorna dispositivo padrão desatualizado no Windows
# ao usar um headset Bluetooth). Vazio = padrão do sistema.
JARVIS_SPEAKER_DEVICE_NAME=

# === Voz do usuário (STT) =====================================================
# Motor padrão: "groq" (Whisper via Groq) | "local" (faster-whisper offline).
JARVIS_STT_ENGINE=groq
JARVIS_STT_GROQ_MODEL=whisper-large-v3-turbo
JARVIS_STT_LOCAL_MODEL=base
# Pasta de download dos pesos do faster-whisper (fica no D:, não no C:).
JARVIS_STT_LOCAL_MODEL_DIR=D:/models/whisper
JARVIS_STT_LANGUAGE=pt
# Trecho do nome do dispositivo de microfone a forçar (contorna o PortAudio não
# atualizar o padrão do Windows ao trocar p/ um headset Bluetooth). Vazio = padrão do SO.
JARVIS_MIC_DEVICE_NAME=

# Ativação ("wake word"):
#  - acoustic = openWakeWord ouve o áudio cru e dispara ao ouvir "hey jarvis"
#               ANTES do STT (só transcreve o comando). Requer 'openwakeword'.
#  - text     = transcreve tudo e procura "jarvis" no texto (sem libs extras).
# O modo acoustic cai para text automaticamente se o openWakeWord não estiver ok.
# Personalização completa em docs/WAKE_WORD.md.
JARVIS_WAKE_MODE=acoustic
# Nome(s) pré-treinado(s) e/ou caminho(s) de modelo customizado, por vírgula.
# Ex.: "hey_jarvis"  |  "hey_jarvis, alexa"  |  "models/penelopo.onnx"
JARVIS_WAKE_MODEL=hey_jarvis
JARVIS_WAKE_THRESHOLD=0.5
# Framework do openWakeWord: vazio = inferir; "onnx" (recomendado) ou "tflite".
# JARVIS_WAKE_FRAMEWORK=
# Palavra usada apenas no modo textual (JARVIS_WAKE_MODE=text).
JARVIS_WAKE_WORD=jarvis

# === Tela + OCR ===============================================================
# Motor OCR: "rapidocr" (padrão) | "tesseract".
JARVIS_OCR_ENGINE=rapidocr
# Caminho do binário do Tesseract (só se usar o fallback). Ex.:
# JARVIS_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Intervalo (s) entre verificações de mudança de tela.
JARVIS_SCREEN_INTERVAL=1.5

# === Visão semântica (LLM) — opcional, DESLIGADA por padrão ===================
# "off" | "anthropic". Quando "anthropic", descreve a tela usando Claude (custo).
JARVIS_VISION_ENGINE=off

# === Ponte com o Jarvis web ===================================================
# WebSocket de eventos de percepção exposto por este serviço (aditivo).
JARVIS_SENSE_WS_HOST=127.0.0.1
JARVIS_SENSE_WS_PORT=8765
# URL base do Jarvis web existente (para disparar tasks via API atual).
JARVIS_WEB_URL=http://localhost:3000

# === Logs =====================================================================
# Nível global: DEBUG | INFO | WARNING | ERROR.
JARVIS_LOG_LEVEL=INFO
